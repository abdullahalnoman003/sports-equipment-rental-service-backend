model gear {
    id             String   @id @default(uuid())
    name           String
    description    String?
    image          String?
    brand          String
    provider_email String
    price          Float
    quantity       Int
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    category_Name  String   
    category       category @relation(fields: [category_Name], references: [name])
    rentals        rental[]
    reviews        review[]
    provider_id    String
    provider        user     @relation(fields: [provider_id], references: [id])

    @@map("Gears")
}
